        fall_transition (scalar) { values ("0.03"); }
      }
      timing () { related_pin : "B"; timing_sense : negative_unate;
        cell_rise (scalar) { values ("0.04"); }
        cell_fall (scalar) { values ("0.03"); }
        rise_transition (scalar) { values ("0.05"); }
        fall_transition (scalar) { values ("0.03"); }
      }
    }
  }

  /* ──────────── AND Gates ──────────── */

  cell (sky130_fd_sc_hd__and2_1) {
    area : 6.2596;
    pin (A) { direction : input; capacitance : 0.0029; }
    pin (B) { direction : input; capacitance : 0.0028; }
    pin (X) {
      direction : output;
      function : "(A&B)";
      timing () { related_pin : "A"; timing_sense : positive_unate;
        cell_rise (scalar) { values ("0.07"); }
        cell_fall (scalar) { values ("0.06"); }
        rise_transition (scalar) { values ("0.08"); }
        fall_transition (scalar) { values ("0.06"); }
      }
      timing () { related_pin : "B"; timing_sense : positive_unate;
        cell_rise (scalar) { values ("0.08"); }
        cell_fall (scalar) { values ("0.06"); }
        rise_transition (scalar) { values ("0.08"); }
        fall_transition (scalar) { values ("0.06"); }
      }
    }
  }

  cell (sky130_fd_sc_hd__and2_2) {
    area : 7.5128;
    pin (A) { direction : input; capacitance : 0.0058; }
    pin (B) { direction : input; capacitance : 0.0056; }
    pin (X) {
      direction : output;
      function : "(A&B)";
      timing () { related_pin : "A"; timing_sense : positive_unate;
        cell_rise (scalar) { values ("0.06"); }
