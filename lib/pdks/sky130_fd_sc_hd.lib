/*
 * sky130_fd_sc_hd__tt_025C_1v80_stripped.lib
 * ──────────────────────────────────────────
 * Stripped version of SKY130 High-Density standard cell library.
 * Contains only the most common cells for educational synthesis.
 *
 * Source: SkyWater 130nm Open PDK (https://github.com/google/skywater-pdk)
 * Corner: Typical-Typical, 25°C, 1.80V
 *
 * NOTE: Timing values are simplified for educational use.
 *       Do NOT use for production tapeout.
 */

library (sky130_fd_sc_hd) {
  technology (cmos);
  delay_model : table_lookup;
  time_unit : "1ns";
  voltage_unit : "1V";
  current_unit : "1mA";
  capacitive_load_unit (1, pf);
  pulling_resistance_unit : "1kohm";
  leakage_power_unit : "1nW";

  nom_process : 1.0;
  nom_temperature : 25.0;
  nom_voltage : 1.80;

  default_cell_leakage_power : 0.0;
  default_fanout_load : 1.0;
  default_output_pin_cap : 0.0;
  default_input_pin_cap : 0.005;
  default_inout_pin_cap : 0.005;
  default_max_transition : 1.5;

  /* ──────────── Inverters ──────────── */

  cell (sky130_fd_sc_hd__inv_1) {
    area : 3.7536;
    cell_leakage_power : 16.87;
    pin (A) {
      direction : input;
      capacitance : 0.0021;
    }
    pin (Y) {
      direction : output;
      function : "(!A)";
      timing () {
        related_pin : "A";
        timing_sense : negative_unate;
        cell_rise (scalar) { values ("0.04"); }
        cell_fall (scalar) { values ("0.02"); }
        rise_transition (scalar) { values ("0.06"); }
        fall_transition (scalar) { values ("0.04"); }
      }
    }
  }

  cell (sky130_fd_sc_hd__inv_2) {
    area : 5.0064;
    cell_leakage_power : 27.38;
    pin (A) {
      direction : input;
      capacitance : 0.0043;
    }
    pin (Y) {
      direction : output;
      function : "(!A)";
      timing () {
        related_pin : "A";
        timing_sense : negative_unate;
        cell_rise (scalar) { values ("0.03"); }
        cell_fall (scalar) { values ("0.02"); }
        rise_transition (scalar) { values ("0.04"); }
        fall_transition (scalar) { values ("0.03"); }
      }
    }
  }

  /* ──────────── Buffers ──────────── */

  cell (sky130_fd_sc_hd__buf_1) {
    area : 5.0064;
    cell_leakage_power : 17.96;
    pin (A) {
