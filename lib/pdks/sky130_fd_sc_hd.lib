    }
    pin (X) {
      direction : output;
      function : "A";
      timing () {
        related_pin : "A";
        timing_sense : positive_unate;
        cell_rise (scalar) { values ("0.08"); }
        cell_fall (scalar) { values ("0.06"); }
        rise_transition (scalar) { values ("0.09"); }
        fall_transition (scalar) { values ("0.06"); }
      }
    }
  }

  cell (sky130_fd_sc_hd__buf_2) {
    area : 6.2596;
    cell_leakage_power : 28.67;
    pin (A) {
      direction : input;
      capacitance : 0.0040;
    }
    pin (X) {
      direction : output;
      function : "A";
      timing () {
        related_pin : "A";
        timing_sense : positive_unate;
        cell_rise (scalar) { values ("0.06"); }
        cell_fall (scalar) { values ("0.05"); }
        rise_transition (scalar) { values ("0.06"); }
        fall_transition (scalar) { values ("0.04"); }
      }
    }
  }

  /* ──────────── NAND Gates ──────────── */

  cell (sky130_fd_sc_hd__nand2_1) {
    area : 5.0064;
    cell_leakage_power : 18.87;
    pin (A) {
      direction : input;
      capacitance : 0.0029;
    }
    pin (B) {
      direction : input;
      capacitance : 0.0028;
    }
    pin (Y) {
      direction : output;
      function : "(!(A&B))";
      timing () {
        related_pin : "A";
        timing_sense : negative_unate;
        cell_rise (scalar) { values ("0.04"); }
        cell_fall (scalar) { values ("0.05"); }
        rise_transition (scalar) { values ("0.06"); }
        fall_transition (scalar) { values ("0.05"); }
      }
      timing () {
        related_pin : "B";
        timing_sense : negative_unate;
        cell_rise (scalar) { values ("0.05"); }
        cell_fall (scalar) { values ("0.04"); }
        rise_transition (scalar) { values ("0.06"); }
        fall_transition (scalar) { values ("0.05"); }
      }
    }
