        rise_transition (scalar) { values ("0.04"); }
        fall_transition (scalar) { values ("0.04"); }
      }
      timing () {
        related_pin : "B";
        timing_sense : negative_unate;
        cell_rise (scalar) { values ("0.04"); }
        cell_fall (scalar) { values ("0.03"); }
        rise_transition (scalar) { values ("0.04"); }
        fall_transition (scalar) { values ("0.04"); }
      }
    }
  }

  cell (sky130_fd_sc_hd__nand3_1) {
    area : 6.2596;
    pin (A) { direction : input; capacitance : 0.0029; }
    pin (B) { direction : input; capacitance : 0.0028; }
    pin (C) { direction : input; capacitance : 0.0028; }
    pin (Y) {
      direction : output;
      function : "(!(A&B&C))";
      timing () { related_pin : "A"; timing_sense : negative_unate;
        cell_rise (scalar) { values ("0.06"); }
        cell_fall (scalar) { values ("0.05"); }
        rise_transition (scalar) { values ("0.07"); }
        fall_transition (scalar) { values ("0.05"); }
      }
      timing () { related_pin : "B"; timing_sense : negative_unate;
        cell_rise (scalar) { values ("0.06"); }
        cell_fall (scalar) { values ("0.05"); }
        rise_transition (scalar) { values ("0.07"); }
        fall_transition (scalar) { values ("0.05"); }
      }
      timing () { related_pin : "C"; timing_sense : negative_unate;
        cell_rise (scalar) { values ("0.06"); }
        cell_fall (scalar) { values ("0.05"); }
        rise_transition (scalar) { values ("0.07"); }
        fall_transition (scalar) { values ("0.05"); }
