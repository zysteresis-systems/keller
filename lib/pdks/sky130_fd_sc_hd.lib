    pin (B) { direction : input; capacitance : 0.0048; }
    pin (X) {
      direction : output;
      function : "(A^B)";
      timing () { related_pin : "A"; timing_sense : non_unate;
        cell_rise (scalar) { values ("0.10"); }
        cell_fall (scalar) { values ("0.08"); }
        rise_transition (scalar) { values ("0.11"); }
        fall_transition (scalar) { values ("0.08"); }
      }
      timing () { related_pin : "B"; timing_sense : non_unate;
        cell_rise (scalar) { values ("0.11"); }
        cell_fall (scalar) { values ("0.09"); }
        rise_transition (scalar) { values ("0.12"); }
        fall_transition (scalar) { values ("0.09"); }
      }
    }
  }

  cell (sky130_fd_sc_hd__xnor2_1) {
