  /* ──────────── D Flip-Flop ──────────── */

  cell (sky130_fd_sc_hd__dfxtp_1) {
    area : 20.0256;
    ff (IQ, IQ_N) {
      next_state : "D";
      clocked_on : "CLK";
    }
    pin (CLK) {
      direction : input;
      clock : true;
      capacitance : 0.0037;
    }
    pin (D) {
      direction : input;
      capacitance : 0.0017;
      timing () {
        related_pin : "CLK";
        timing_type : setup_rising;
        cell_rise (scalar) { values ("0.04"); }
        cell_fall (scalar) { values ("0.04"); }
      }
      timing () {
        related_pin : "CLK";
        timing_type : hold_rising;
        cell_rise (scalar) { values ("-0.01"); }
        cell_fall (scalar) { values ("-0.01"); }
      }
    }
    pin (Q) {
      direction : output;
      function : "IQ";
      timing () {
        related_pin : "CLK";
        timing_type : rising_edge;
        cell_rise (scalar) { values ("0.28"); }
        cell_fall (scalar) { values ("0.26"); }
        rise_transition (scalar) { values ("0.09"); }
        fall_transition (scalar) { values ("0.07"); }
      }
    }
  }

  /* ──────────── D Flip-Flop with Reset ──────────── */

  cell (sky130_fd_sc_hd__dfrtp_1) {
    area : 26.2848;
    ff (IQ, IQ_N) {
      next_state : "D";
      clocked_on : "CLK";
      clear : "(!RESET_B)";
    }
    pin (CLK) {
      direction : input;
      clock : true;
      capacitance : 0.0037;
    }
    pin (D) {
      direction : input;
      capacitance : 0.0017;
      timing () {
        related_pin : "CLK";
        timing_type : setup_rising;
        cell_rise (scalar) { values ("0.05"); }
        cell_fall (scalar) { values ("0.05"); }
      }
      timing () {
        related_pin : "CLK";
        timing_type : hold_rising;
        cell_rise (scalar) { values ("-0.01"); }
        cell_fall (scalar) { values ("-0.01"); }
      }
    }
    pin (RESET_B) {
      direction : input;
      capacitance : 0.0035;
    }
    pin (Q) {
      direction : output;
      function : "IQ";
      timing () {
        related_pin : "CLK";
        timing_type : rising_edge;
        cell_rise (scalar) { values ("0.32"); }
        cell_fall (scalar) { values ("0.30"); }
        rise_transition (scalar) { values ("0.10"); }
        fall_transition (scalar) { values ("0.08"); }
      }
    }
  }

