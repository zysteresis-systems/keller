  /* ──────────── MUX ──────────── */

  cell (sky130_fd_sc_hd__mux2_1) {
    area : 10.0128;
    pin (A0) { direction : input; capacitance : 0.0031; }
    pin (A1) { direction : input; capacitance : 0.0030; }
    pin (S) { direction : input; capacitance : 0.0044; }
    pin (X) {
      direction : output;
      function : "((A0&(!S))|(A1&S))";
      timing () { related_pin : "A0"; timing_sense : positive_unate;
        cell_rise (scalar) { values ("0.12"); }
        cell_fall (scalar) { values ("0.10"); }
        rise_transition (scalar) { values ("0.09"); }
        fall_transition (scalar) { values ("0.07"); }
      }
      timing () { related_pin : "A1"; timing_sense : positive_unate;
        cell_rise (scalar) { values ("0.11"); }
        cell_fall (scalar) { values ("0.09"); }
        rise_transition (scalar) { values ("0.09"); }
        fall_transition (scalar) { values ("0.07"); }
